# Copy to .env locally and fill secrets there. Do not commit .env.
HPC_PROVIDER=leonardo
HPC_USERNAME=
HPC_PASSWORD=
HPC_HOST=login01-ext.leonardo.cineca.it
HPC_HOST_ALTERNATES=login02-ext.leonardo.cineca.it,login05-ext.leonardo.cineca.it,login07-ext.leonardo.cineca.it
HPC_SSH_PORT=22
HPC_TWO_FACTOR_AUTH=false

HPC_SLURM_PARTITION=boost_usr_prod
HPC_SLURM_RESERVATION=s_tra_ncc
HPC_GPUS_PER_TASK=1
HPC_CPUS_PER_TASK=8
HPC_MEM_PER_GPU=120GB
HPC_TIME_LIMIT=00:30:00

HPC_SCRATCH_DIR=$SCRATCH
HPC_PUBLIC_DIR=$PUBLIC

# Compute nodes need a proxy only for low-bandwidth package/model access.
# Fill this from the official event materials if needed; do not commit secrets.
HPC_PROXY_URL=
